# Sao chép file này thành .env và điền giá trị thực

# Bảo mật — BẮT BUỘC đổi khi deploy production
SECRET_KEY=your-very-secret-key-change-me

# Session
TOKEN_TTL_SECONDS=300

# Puzzle
SNAP_THRESHOLD=10
PIECE_SIZE=60
CANVAS_WIDTH=400

# Phân tích hành vi
MIN_EVENTS=6
MAX_AVG_SPEED=5
MIN_AVG_SPEED=0.001
MIN_DIRECTION_CHANGES=1

# Thư mục ảnh
IMAGES_DIR=static/images
